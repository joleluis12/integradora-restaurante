        "projectId": "ea7f4f74-be13-4e9d-8e7a-14c570542bba"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ea7f4f74-be13-4e9d-8e7a-14c570542bba"
    }
